<UserControl x:Class="FabricationSample.UserControls.ServiceButtonsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="610" Loaded="UserControl_Loaded" Unloaded="UserControl_Unloaded">
  <TabControl Name="tbServiceTab" SelectionChanged="tbServiceTab_OnSelectionChanged"
              HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="100">
    <TabControl.ItemTemplate>
      <DataTemplate>
        <TextBlock Text="{Binding Name}">
          <TextBlock.ContextMenu>
            <ContextMenu>
              <MenuItem Header="Delete Tab" Click="deleteServiceTab_Click"/>
              <MenuItem Header="Edit Tab Name" Click="editServiceTabName_Click"/>
              <Separator/>
              <MenuItem Header="Select All Buttons" Click="selectAllButtons_Click"/>
              <Separator/>
              <MenuItem Header="Copy Tab" Click="copyTabButtons_Click" ToolTip="Copy all buttons in this tab to clipboard"/>
              <MenuItem Header="Paste Tab" Click="pasteTabButtons_Click" ToolTip="Paste copied buttons into this tab"/>
            </ContextMenu>
          </TextBlock.ContextMenu>
        </TextBlock>
      </DataTemplate>
    </TabControl.ItemTemplate>
    <TabControl.ContentTemplate>
      <DataTemplate>
        <ListView x:Name="lvSelectServiceButton" ItemsSource="{Binding Buttons}"
                  SelectionChanged="lvSelectServiceButton_SelectionChanged"
                  ContextMenuOpening="buttonContextOpening"
                  SelectionMode="Extended"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  HorizontalAlignment="Stretch"
                  MinHeight="100"
                  PreviewMouseLeftButtonDown="lvSelectServiceButton_PreviewMouseLeftButtonDown"
                  PreviewMouseMove="lvSelectServiceButton_PreviewMouseMove"
                  PreviewMouseLeftButtonUp="lvSelectServiceButton_PreviewMouseLeftButtonUp">
          <ListView.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel/>
            </ItemsPanelTemplate>
          </ListView.ItemsPanel>
          <ListView.ItemTemplate>
            <DataTemplate>
              <Image Source="{Binding Image}" Width="50" Height="50" ToolTip="{Binding Button.Name}" Margin="10,10">
                <Image.ContextMenu>
                  <ContextMenu>
                    <MenuItem Header="Delete Button" Click="deleteServiceButton_Click"></MenuItem>
                    <MenuItem Header="Edit Button" Click="editServiceButton_Click"></MenuItem>
                    <MenuItem Header="Move Button Up" Click="moveButtonUp_Click"></MenuItem>
                    <MenuItem Header="Move Button Down" Click="moveButtonDown_Click"></MenuItem>
                    <Separator/>
                    <MenuItem Header="Add Button Item" Click="addButtonItem_Click"></MenuItem>
                    <MenuItem Header="Edit Button Item" ItemsSource="{Binding Button.ServiceButtonItems}" Click="editButtonItem_Click">
                      <MenuItem.ItemTemplate>
                        <DataTemplate>
                          <TextBlock Text="{Binding ServiceTemplateCondition.Description}"/>
                        </DataTemplate>
                      </MenuItem.ItemTemplate>
                    </MenuItem>
                    <MenuItem Header="Delete Button Item" ItemsSource="{Binding Button.ServiceButtonItems}" Click="deleteButtonItem_Click">
                      <MenuItem.ItemTemplate>
                        <DataTemplate>
                          <TextBlock Text="{Binding ServiceTemplateCondition.Description}"/>
                        </DataTemplate>
                      </MenuItem.ItemTemplate>
                    </MenuItem>
                  </ContextMenu>
                </Image.ContextMenu>
              </Image>
            </DataTemplate>
          </ListView.ItemTemplate>
        </ListView>
      </DataTemplate>
    </TabControl.ContentTemplate>
  </TabControl>
</UserControl>
