<Window x:Class="FabricationSample.PriceListSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Price List"
        Height="300" Width="400"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border x:Name="border_1"
            BorderBrush="#FF0078D7"
            BorderThickness="1"
            Background="#FF2D2D30"
            CornerRadius="5">

        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Grid Grid.Row="0">
                <Label x:Name="WindowTitle"
                       Content="Select Price List to Import"
                       Foreground="White"
                       FontSize="14"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>
                <Image x:Name="CloseImage"
                       Source="/Resources/closePanelActive.png"
                       Width="16" Height="16"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       Margin="0,0,5,0"
                       MouseLeftButtonDown="CloseImage_MouseLeftButtonDown"
                       Cursor="Hand"/>
            </Grid>

            <!-- Supplier Group -->
            <StackPanel Grid.Row="1" Margin="5,5,5,0">
                <Label Content="Supplier Group:" Foreground="White" Padding="0,0,0,3"/>
                <ComboBox x:Name="cboSupplierGroup"
                          Height="28"
                          DisplayMemberPath="Name"
                          SelectionChanged="cboSupplierGroup_SelectionChanged"/>
            </StackPanel>

            <!-- Price List -->
            <StackPanel Grid.Row="2" Margin="5,10,5,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Price List:" Foreground="White" Padding="0,0,0,3"/>
                    <TextBlock x:Name="txtEntryCount"
                               Grid.Column="1"
                               Foreground="#FF999999"
                               VerticalAlignment="Center"
                               Margin="0,0,0,3"/>
                </Grid>
                <ComboBox x:Name="cboPriceList"
                          Height="28"
                          DisplayMemberPath="Name"
                          SelectionChanged="cboPriceList_SelectionChanged"/>
            </StackPanel>

            <!-- Action Buttons -->
            <StackPanel Grid.Row="4"
                       Orientation="Horizontal"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center">
                <Button x:Name="btnOk"
                        Content="OK"
                        Width="80" Height="35"
                        Margin="0,0,10,0"
                        IsEnabled="False"
                        Click="btnOk_Click"/>
                <Button x:Name="btnCancel"
                        Content="Cancel"
                        Width="80" Height="35"
                        Click="btnCancel_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
