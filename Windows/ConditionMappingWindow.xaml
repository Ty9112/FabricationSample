<Window x:Class="FabricationSample.Windows.ConditionMappingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Map Conditions"
        Height="500" Width="650"
        MinHeight="350" MinWidth="500"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border BorderBrush="#FF0078D7"
            BorderThickness="1"
            Background="#FF2D2D30"
            CornerRadius="5">

        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Grid Grid.Row="0">
                <Label Content="Map Source Conditions to Target Conditions"
                       Foreground="White"
                       FontSize="14"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>
                <Image Source="/Resources/closePanelActive.png"
                       Width="16" Height="16"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       Margin="0,0,5,0"
                       MouseLeftButtonDown="CloseImage_MouseLeftButtonDown"
                       Cursor="Hand"/>
            </Grid>

            <!-- Instructions -->
            <TextBlock Grid.Row="1"
                       Foreground="White"
                       TextWrapping="Wrap"
                       Margin="5,5,5,10"
                       Text="Some conditions have the same name but different ranges. Choose which version to use for each condition in the new template. Conflicts are highlighted in orange."/>

            <!-- Condition Mapping List -->
            <Border Grid.Row="2"
                    BorderBrush="#FF3F3F46"
                    BorderThickness="1"
                    Margin="0,0,0,5">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="mappingsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="2,1" Padding="5,4" CornerRadius="2">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsConflict}" Value="True">
                                                    <Setter Property="Background" Value="#33FF8C00"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsAutoMapped}" Value="True">
                                                    <Setter Property="Background" Value="#2200AA00"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="30"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding SourceLabel}"
                                                       Foreground="White"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding SourceRange}"
                                                       Foreground="#FFAAAAAA"
                                                       FontSize="11"/>
                                            <TextBlock Text="{Binding SourceTemplateName}"
                                                       Foreground="#FF888888"
                                                       FontSize="10"
                                                       FontStyle="Italic"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1"
                                                   Text="&#x2192;"
                                                   Foreground="#FF888888"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   FontSize="14"/>
                                        <ComboBox Grid.Column="2"
                                                  ItemsSource="{Binding TargetOptions}"
                                                  SelectedItem="{Binding SelectedTarget, Mode=TwoWay}"
                                                  VerticalAlignment="Center"
                                                  Height="25"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <!-- Action Buttons -->
            <StackPanel Grid.Row="3"
                       Orientation="Horizontal"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center">
                <TextBlock x:Name="txtSummary"
                           Foreground="#FFAAAAAA"
                           VerticalAlignment="Center"
                           Margin="0,0,15,0"/>
                <Button x:Name="btnOk"
                        Content="Continue"
                        Width="100" Height="35"
                        Margin="0,0,10,0"
                        Click="btnOk_Click"/>
                <Button x:Name="btnCancel"
                        Content="Cancel"
                        Width="80" Height="35"
                        Click="btnCancel_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
